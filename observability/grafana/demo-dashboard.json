{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Demo Service",
  "uid": "demo-service",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(http_requests_total[1m])", "legendFormat": "req/s" }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "rate(http_requests_errors_total[1m])", "legendFormat": "errors/s" }
      ]
    },
    {
      "id": 3,
      "title": "p95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(request_duration_seconds_bucket[1m]))",
          "legendFormat": "p95"
        }
      ]
    }
  ]
}
